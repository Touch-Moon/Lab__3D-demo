'use client'

import dynamic from 'next/dynamic'
import { useState } from 'react'

const Scene = dynamic(() => import('./Scene'), { ssr: false })

const STATUS_COLOR: Record<string, string> = {
  available:   '#22c55e',
  sold:        '#cbd5e1',
  phase2:      '#f97316',
  ready:       '#3b82f6',
  commercial:  '#8b5cf6',
  unavailable: '#e2e8f0',
}

const STATUS_LABEL: Record<string, string> = {
  available:   'Available',
  sold:        'Sold',
  phase2:      'Phase 2',
  ready:       'Ready to Develop',
  commercial:  'Commercial',
  unavailable: 'Unavailable',
}

const LEGEND = Object.entries(STATUS_LABEL)

export default function ThreeDemoPage() {
  const [hoveredId, setHoveredId] = useState<string | null>(null)

  return (
    <main className="h-screen bg-[#0f1117] flex flex-col overflow-hidden">
      {/* Header */}
      <div className="px-8 py-6 flex items-center justify-between">
        <div>
          <p className="text-xs font-semibold uppercase tracking-widest text-amber-400 mb-1">
            3D Demo
          </p>
          <h1 className="text-2xl font-bold text-white">Langill Farm — Lot Overview</h1>
          <p className="text-gray-400 text-sm mt-0.5">Steinbach, Manitoba · 127 Lots</p>
        </div>
        <a
          href="/map-demo"
          className="text-xs text-gray-400 hover:text-white border border-gray-700 hover:border-gray-400 px-4 py-2 rounded-lg transition-colors"
        >
          ← 2D Map
        </a>
      </div>

      {/* Canvas */}
      <div className="flex-1 relative min-h-0">
        <Scene onHover={setHoveredId} hoveredId={hoveredId} />

        {/* Hover label */}
        {hoveredId && (
          <div className="absolute top-4 left-1/2 -translate-x-1/2 bg-black/70 backdrop-blur text-white text-sm px-4 py-2 rounded-full pointer-events-none">
            Lot {hoveredId}
          </div>
        )}

        {/* Controls hint */}
        <div className="absolute bottom-4 left-1/2 -translate-x-1/2 text-gray-500 text-xs text-center pointer-events-none">
          Drag to rotate · Scroll to zoom · Hover a lot
        </div>
      </div>

      {/* Legend */}
      <div className="px-8 py-5 border-t border-gray-800 flex flex-wrap gap-4 items-center">
        {LEGEND.map(([status, label]) => (
          <div key={status} className="flex items-center gap-2">
            <span
              className="w-3 h-3 rounded-sm flex-shrink-0"
              style={{ background: STATUS_COLOR[status] }}
            />
            <span className="text-xs text-gray-400">{label}</span>
          </div>
        ))}
      </div>
    </main>
  )
}
